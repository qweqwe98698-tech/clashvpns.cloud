---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
articles.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="储物戒 - 柳如烟的百宝箱">
  <div class="fixed inset-0 z-[-1] pointer-events-none" style="background-color: #FFFDF8; background-image: radial-gradient(#FFD6E7 1px, transparent 1px); background-size: 20px 20px;"></div>

  <div class="max-w-4xl mx-auto px-4 py-16">
    <header class="text-center mb-16 relative">
      <div class="absolute -top-8 right-1/4 text-6xl transform rotate-12 opacity-80">💍</div>
      <h1 class="text-5xl md:text-6xl font-handwriting text-sakura-primary mb-6 drop-shadow-sm">柳如烟的储物戒</h1>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto bg-white/60 p-4 rounded-xl border border-sakura-secondary/50 backdrop-blur-sm shadow-sm">
        这里存放着我收集的各种折腾笔记、长文解析和奇珍异宝。随便看看吧！
      </p>
    </header>

    <div class="space-y-8 relative before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-transparent before:via-sakura-primary/30 before:to-transparent">
      {articles.map((article, index) => (
        <div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group is-active">
          <!-- Timeline dot -->
          <div class="flex items-center justify-center w-10 h-10 rounded-full border-4 border-white bg-sakura-primary/20 group-hover:bg-sakura-primary text-sakura-primary group-hover:text-white shadow shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 transition-colors duration-300 z-10">
            <svg class="w-4 h-4 fill-current" viewBox="0 0 16 16"><path d="M8 0a8 8 0 1 0 8 8 8.009 8.009 0 0 0-8-8Zm0 12a4 4 0 1 1 0-8 4 4 0 0 1 0 8Z"/></svg>
          </div>
          
          <!-- Card -->
          <a href={`/ring/${article.id}`} class="w-[calc(100%-3rem)] md:w-[calc(50%-2.5rem)] bg-white p-6 rounded-2xl shadow-sm border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group-hover:border-sakura-primary/40 relative">
            
            <!-- Tape decoration -->
            <div class="absolute -top-3 left-1/2 -translate-x-1/2 w-16 h-6 bg-sakura-secondary/40 rotate-2 shadow-sm" style="mix-blend-mode: multiply;"></div>
            
            <div class="flex flex-wrap gap-2 mb-3">
              {article.data.tags.map(tag => (
                <span class="text-xs font-bold px-2 py-1 bg-gray-50 text-gray-500 rounded-md border border-gray-100">{tag}</span>
              ))}
              <span class="text-xs font-medium px-2 py-1 bg-sakura-primary/10 text-sakura-primary rounded-md border border-sakura-primary/20">
                {article.data.date.toLocaleDateString('zh-CN')}
              </span>
            </div>
            
            <h3 class="text-2xl font-bold text-gray-800 mb-3 group-hover:text-sakura-primary transition-colors font-handwriting">
              {article.data.title}
            </h3>
            
            <p class="text-gray-600 text-sm line-clamp-3 leading-relaxed">
              {article.data.description}
            </p>

            <div class="mt-4 text-sm font-bold text-sakura-primary/70 group-hover:text-sakura-primary flex items-center gap-1">
              翻阅这枚玉简 <span class="group-hover:translate-x-1 transition-transform">&rarr;</span>
            </div>
          </a>
        </div>
      ))}
    </div>
  </div>
</Layout>
