---
import Layout from '../layouts/Layout.astro';
---

<Layout title="柳如烟 - 稳定高速机场推荐与教程">
  <!-- Scrapbook Grid Background -->
  <div class="fixed inset-0 z-[-1] pointer-events-none" style="background-color: #FFFDF8; background-image: linear-gradient(transparent 23px, #FFD6E7 24px), linear-gradient(90deg, transparent 23px, #FFD6E7 24px); background-size: 24px 24px;">
    <!-- Fade out edges slightly to look like a page -->
    <div class="absolute inset-0 shadow-[inset_0_0_100px_rgba(0,0,0,0.05)]"></div>
  </div>

  <!-- Hero Section -->
  <section class="relative pt-24 pb-20 flex flex-col items-center justify-center text-center px-4">
    <!-- Main Scrapbook Title Card -->
    <div class="relative bg-white p-8 md:p-12 shadow-[2px_4px_16px_rgba(0,0,0,0.08)] max-w-3xl w-full transform -rotate-1 border border-gray-100">
      <!-- Washi Tapes -->
      <div class="absolute -top-3 -left-4 w-16 h-6 bg-[#FFB6C1]/80 -rotate-6 backdrop-blur-sm shadow-sm z-10" style="mix-blend-mode: multiply;"></div>
      <div class="absolute -bottom-3 -right-4 w-20 h-6 bg-[#A7F3D0]/80 -rotate-3 backdrop-blur-sm shadow-sm z-10" style="mix-blend-mode: multiply;"></div>
      
      <!-- Doodle Element -->
      <div class="absolute top-4 right-8 text-4xl transform rotate-12 opacity-80">🌸</div>
      <div class="absolute bottom-8 left-8 text-3xl transform -rotate-12 opacity-80">✨</div>

      <h1 class="text-5xl md:text-6xl font-handwriting text-sakura-primary mb-6 drop-shadow-sm tracking-wide">
        柳如烟的奇妙手账本
      </h1>
      <p class="text-lg md:text-xl text-sakura-text/80 max-w-2xl mx-auto leading-relaxed mb-10 font-medium">
        萌新也能看懂的机场推荐与使用指南。<br/>手把手教你配置各大主流客户端，轻松穿梭互联网世界 📝
      </p>
      
      <div class="flex flex-col sm:flex-row gap-5 justify-center items-center mt-6">
        <a href="/download" class="relative group px-8 py-3 bg-sakura-primary text-white font-bold text-lg shadow-[2px_4px_0px_#D6336C] hover:translate-y-[2px] hover:shadow-[0px_0px_0px_#D6336C] transition-all transform rotate-1">
          📥 客户端下载大全
        </a>
        <a href="/guides" class="relative px-8 py-3 bg-[#FFF8FA] text-sakura-primary border-2 border-dashed border-sakura-primary font-bold text-lg hover:bg-sakura-secondary/20 transition-all transform -rotate-1">
          📖 新手保姆教程
        </a>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="text-center mb-16 transform rotate-1">
      <h2 class="text-4xl font-handwriting text-sakura-text/90 inline-block relative">
        为什么选择柳如烟？
        <svg class="absolute -bottom-2 left-0 w-full h-3 text-sakura-primary/40" viewBox="0 0 100 20" preserveAspectRatio="none">
          <path d="M0 10 Q 50 20 100 10" stroke="currentColor" stroke-width="4" fill="none" stroke-linecap="round"/>
        </svg>
      </h2>
    </div>
    
    <div class="grid md:grid-cols-3 gap-10">
      <!-- Feature 1: Polaroid Style (Link to Recommend) -->
      <a href="/recommend" class="group block bg-white p-4 pb-12 shadow-xl transform -rotate-2 hover:rotate-1 hover:-translate-y-2 hover:shadow-2xl transition-all duration-300 relative border border-gray-100 cursor-pointer">
        <div class="absolute -top-4 left-1/2 -translate-x-1/2 w-12 h-6 bg-[#BFDBFE]/80 rotate-2 shadow-sm z-10 transition-transform group-hover:scale-110" style="mix-blend-mode: multiply;"></div>
        <div class="bg-gray-100 h-40 mb-4 flex flex-col items-center justify-center rounded-sm overflow-hidden border border-gray-200 relative group-hover:bg-[#EFF6FF] transition-colors">
          <span class="text-5xl transform group-hover:scale-110 transition-transform duration-300">⚡</span>
          <div class="absolute bottom-2 text-xs font-bold text-blue-500 bg-blue-100 px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity">点击查看推荐机场</div>
        </div>
        <h3 class="text-2xl font-handwriting text-sakura-text/90 mb-2 text-center group-hover:text-blue-600 transition-colors">稳定高速</h3>
        <p class="text-sm text-sakura-text/70 text-center font-medium mb-3">精选经过长期测试的稳定专线机场，看视频、打游戏不掉线。</p>
        <div class="text-center">
          <span class="inline-block bg-[#FFF8FA] text-sakura-primary border border-sakura-primary/30 text-[10px] font-bold px-2 py-0.5 rounded-full">🏆 已为您评测 3 家顶尖专线</span>
        </div>
      </a>

      <!-- Feature 2: Torn Paper Style (Link to Download) -->
      <a href="/download" class="group block bg-[#FFFDF8] p-6 shadow-md transform rotate-3 hover:-rotate-1 hover:-translate-y-2 hover:shadow-xl transition-all duration-300 relative cursor-pointer" style="clip-path: polygon(0% 2%, 100% 0%, 98% 98%, 2% 100%); border: 1px solid #e5e7eb;">
        <div class="absolute -top-3 -right-2 w-12 h-6 bg-[#FDE68A]/80 -rotate-12 shadow-sm z-10 transition-transform group-hover:scale-110" style="mix-blend-mode: multiply;"></div>
        <div class="text-4xl mb-4 transform group-hover:scale-110 transition-transform duration-300 origin-left">📱</div>
        <h3 class="text-2xl font-handwriting text-sakura-primary mb-2 group-hover:text-sakura-primary/80 transition-colors">全平台支持</h3>
        <p class="text-sm text-sakura-text/80 font-medium mb-4">详细覆盖 Windows、macOS、iOS、安卓甚至路由器，一份订阅全端通用。</p>
        <div class="border-t border-dashed border-sakura-secondary/50 pt-3">
          <span class="inline-block bg-sakura-primary/10 text-sakura-primary text-[10px] font-bold px-2 py-0.5 rounded shadow-sm">📦 本站已收录 44 款全平台客户端</span>
        </div>
      </a>

      <!-- Feature 3: Sticky Note Style (Link to Guides) -->
      <a href="/guides" class="group block bg-[#FEF9C3] p-6 shadow-md transform -rotate-3 hover:rotate-1 hover:-translate-y-2 hover:shadow-xl transition-all duration-300 relative border-t-8 border-yellow-400 cursor-pointer">
        <div class="absolute -top-6 left-1/2 -translate-x-1/2 text-2xl drop-shadow-md z-10 group-hover:-translate-y-1 transition-transform">📌</div>
        <div class="flex justify-between items-start mb-4 mt-2">
          <div class="text-4xl transform group-hover:rotate-12 transition-transform duration-300">💖</div>
          <span class="text-xs font-bold text-yellow-800 bg-yellow-200/50 px-2 py-1 rounded">小白必看</span>
        </div>
        <h3 class="text-2xl font-handwriting text-yellow-700 mb-2 group-hover:text-yellow-900 transition-colors">新手友好</h3>
        <p class="text-sm text-yellow-800/80 font-medium mb-4">提供极其详尽的图文保姆教程，从零开始手把手教你如何导入订阅。</p>
        <div class="bg-yellow-100/50 p-2 rounded border border-yellow-200/50">
          <span class="text-[11px] text-yellow-800 font-bold block">📖 内含 40+ 篇动态专属超级长文教程</span>
        </div>
      </a>
    </div>
  </section>
  
  <!-- Latest Articles Preview -->
  <section class="max-w-5xl mx-auto px-4 py-16 mb-20 relative">
    <!-- Washi Tape for the section -->
    <div class="absolute top-10 -left-6 w-24 h-8 bg-sakura-secondary/60 rotate-45 backdrop-blur-sm shadow-sm z-10" style="mix-blend-mode: multiply;"></div>

    <div class="bg-white p-8 md:p-12 shadow-[4px_6px_20px_rgba(0,0,0,0.06)] transform rotate-1 border border-sakura-secondary/30 relative">
      <div class="absolute -top-4 right-10 w-20 h-6 bg-[#FFB6C1]/80 rotate-2 shadow-sm" style="mix-blend-mode: multiply;"></div>
      
      <div class="flex justify-between items-end mb-8 border-b-2 border-dashed border-sakura-secondary/50 pb-4">
        <h2 class="text-3xl font-handwriting text-sakura-primary">📝 精选教程预览</h2>
        <a href="/guides" class="text-sakura-text/60 text-sm font-bold hover:text-sakura-primary transition-colors">
          查看全部教程 &rarr;
        </a>
      </div>
      
      <div class="grid md:grid-cols-2 gap-6">
        <!-- We link dynamically to two of the most popular generated clients -->
        <!-- Article Card 1 -->
        <a href="/guides/clash-verge-rev" class="group flex items-center gap-4 p-4 hover:bg-sakura-secondary/10 rounded-lg transition-colors border border-transparent hover:border-sakura-secondary/30">
          <div class="w-16 h-16 bg-gray-50 border border-gray-200 rounded-md shadow-sm flex items-center justify-center transform -rotate-3 group-hover:rotate-0 transition-transform flex-shrink-0">
            <span class="text-2xl">🖥️</span>
          </div>
          <div>
            <h3 class="text-lg font-bold text-sakura-text/90 group-hover:text-sakura-primary transition-colors leading-tight mb-1">【2026 全面解析】Clash Verge Rev 终极配置保姆级教程</h3>
            <p class="text-xs text-sakura-text/60 mt-1 line-clamp-1">目前最流行、界面好看的代理客户端配置指南...</p>
            <div class="text-[10px] text-sakura-primary mt-2 bg-sakura-primary/10 px-2 py-0.5 rounded w-fit">Windows/macOS</div>
          </div>
        </a>

        <!-- Article Card 2 -->
        <a href="/guides/shadowrocket" class="group flex items-center gap-4 p-4 hover:bg-sakura-secondary/10 rounded-lg transition-colors border border-transparent hover:border-sakura-secondary/30">
          <div class="w-16 h-16 bg-gray-50 border border-gray-200 rounded-md shadow-sm flex items-center justify-center transform rotate-2 group-hover:rotate-0 transition-transform flex-shrink-0">
            <span class="text-2xl">📱</span>
          </div>
          <div>
            <h3 class="text-lg font-bold text-sakura-text/90 group-hover:text-sakura-primary transition-colors leading-tight mb-1">【2026 全面解析】Shadowrocket 下载与终极配置</h3>
            <p class="text-xs text-sakura-text/60 mt-1 line-clamp-1">iOS 端必备的小火箭，支持各种协议的终极教程...</p>
            <div class="text-[10px] text-sakura-primary mt-2 bg-sakura-primary/10 px-2 py-0.5 rounded w-fit">iOS</div>
          </div>
        </a>
      </div>
    </div>
  </section>
</Layout>
