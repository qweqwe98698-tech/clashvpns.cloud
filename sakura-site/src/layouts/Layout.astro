---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <!-- 引入手写风中文字体 Zhi Mang Xing -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Zhi+Mang+Xing&display=swap" rel="stylesheet">
  </head>
  <body>
    <!-- 樱花特效容器 -->
    <div id="sakura-container" class="fixed inset-0 pointer-events-none overflow-hidden z-[9999]"></div>
    
    <!-- 导航栏 -->
    <nav class="sticky top-0 w-full bg-white/60 backdrop-blur-md border-b border-sakura-secondary/50 z-40">
      <div class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/" class="text-2xl font-handwriting text-sakura-primary flex items-center gap-2">
          🌸 柳如烟指北
        </a>
        <div class="hidden md:flex gap-6 text-sakura-text font-medium">
          <a href="/" class="hover:text-sakura-primary transition-colors">首页</a>
          <a href="/guides" class="hover:text-sakura-primary transition-colors">新手教程</a>
          <a href="/recommend" class="hover:text-sakura-primary transition-colors">机场推荐</a>
          <a href="/ring" class="hover:text-sakura-primary transition-colors flex items-center gap-1"><span class="text-lg">💍</span> 储物戒</a>
        </div>
      </div>
    </nav>

    <main class="min-h-screen">
      <slot />
    </main>

    <footer class="bg-sakura-secondary/20 py-10 mt-20 text-center text-sm text-sakura-text/70 border-t border-sakura-secondary/30 relative z-40">
      <div class="max-w-5xl mx-auto px-4 flex flex-col items-center space-y-4">
        <!-- Site Links -->
        <div class="flex flex-wrap justify-center gap-6 font-medium">
          <a href="#" class="hover:text-sakura-primary transition-colors">站点说明</a>
          <a href="/sitemap-index.xml" class="hover:text-sakura-primary transition-colors">网站地图</a>
          <a href="/ring" class="hover:text-sakura-primary transition-colors">储物戒内链</a>
        </div>
        
        <!-- Copyright & ICP -->
        <p>© 2026 柳如烟指北. 樱花校园动漫风版. 备案号：<a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener" class="hover:text-sakura-primary transition-colors">萌ICP备20260621号-1</a></p>
        
        <!-- Friendly Links (SEO Backlinks, Passing Weight) -->
        <div class="flex flex-wrap justify-center items-center gap-4 text-xs text-sakura-text/60 pt-2 w-full max-w-lg">
          <span>友情链接：</span>
          <a href="https://airporthub.pro/" target="_blank" rel="noopener" class="hover:text-sakura-primary transition-colors hover:underline">机场推荐科学上网教程</a>
          <span class="text-gray-300">|</span>
          <a href="https://fanfanqiang.net/" target="_blank" rel="noopener" class="hover:text-sakura-primary transition-colors hover:underline">高性价比机场推荐指南</a>
        </div>
      </div>
    </footer>

    <!-- 返回顶部按钮 -->
    <button 
      id="back-to-top" 
      class="fixed bottom-8 right-8 md:bottom-[140px] md:right-10 z-50 bg-white/90 backdrop-blur-md text-sakura-primary p-3.5 rounded-full shadow-xl border border-sakura-primary/20 opacity-0 translate-y-10 pointer-events-none transition-all duration-500 hover:bg-sakura-primary hover:text-white hover:shadow-sakura-primary/40 hover:-translate-y-2 group"
      aria-label="回到顶部"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 transform group-hover:-translate-y-1 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 11l7-7 7 7M12 4v16" />
      </svg>
    </button>

    <script>
      // 返回顶部交互逻辑
      const backToTopBtn = document.getElementById('back-to-top');
      if (backToTopBtn) {
        window.addEventListener('scroll', () => {
          if (window.scrollY > 400) {
            backToTopBtn.classList.remove('opacity-0', 'translate-y-10', 'pointer-events-none');
            backToTopBtn.classList.add('opacity-100', 'translate-y-0');
          } else {
            backToTopBtn.classList.add('opacity-0', 'translate-y-10', 'pointer-events-none');
            backToTopBtn.classList.remove('opacity-100', 'translate-y-0');
          }
        }, { passive: true });

        backToTopBtn.addEventListener('click', () => {
          window.scrollTo({
            top: 0,
            behavior: 'smooth'
          });
        });
      }

      // 简单的樱花飘落脚本
      const container = document.getElementById('sakura-container');
      const createSakura = () => {
        if (!container) return;
        const sakura = document.createElement('div');
        sakura.classList.add('sakura');
        
        // 随机大小
        const size = Math.random() * 8 + 8; 
        sakura.style.width = `${size}px`;
        sakura.style.height = `${size}px`;
        
        // 用 CSS 绘制一片樱花花瓣
        sakura.style.backgroundColor = '#FF6B9D';
        sakura.style.borderRadius = '50% 0 50% 50%'; 
        sakura.style.opacity = (Math.random() * 0.5 + 0.3).toString();
        
        // 随机位置
        sakura.style.left = `${Math.random() * 100}vw`;
        
        // 随机下落时间
        const duration = Math.random() * 4 + 6;
        sakura.style.animationDuration = `${duration}s`;
        
        container.appendChild(sakura);
        
        // 动画结束后移除
        setTimeout(() => {
          sakura.remove();
        }, duration * 1000);
      };

      // 每 300ms 生成一片樱花
      setInterval(createSakura, 300);
    </script>
  </body>
</html>
