---
import Layout from './Layout.astro';
const { frontmatter } = Astro.props;
---

<Layout title={frontmatter.title}>
  <article class="max-w-4xl mx-auto px-4 py-12">
    <!-- Pink Sticky Note Container for the Article -->
    <div class="bg-[#FFFDF8] p-8 md:p-12 rounded-sm shadow-xl border-t-8 border-sakura-primary relative mt-8">
      <!-- Tape/Pin decoration -->
      <div class="absolute -top-4 left-1/2 -translate-x-1/2 w-16 h-6 bg-[#FFD6E7]/80 rotate-2 backdrop-blur-sm shadow-sm"></div>
      
      <header class="mb-8 border-b-2 border-sakura-secondary/30 pb-6">
        <h1 class="text-4xl font-handwriting text-sakura-primary mb-4">{frontmatter.title}</h1>
        <div class="flex gap-4 text-sakura-text/70 text-sm">
          <span>🌸 适用平台: {frontmatter.platform}</span>
          <span>📅 更新时间: {frontmatter.date}</span>
        </div>
      </header>

      <div class="markdown-content text-sakura-text leading-relaxed">
        <slot />
      </div>

      <div class="mt-12 text-center">
        <a href="/" class="px-6 py-2 bg-sakura-secondary/20 text-sakura-primary rounded-full hover:bg-sakura-secondary/40 transition-colors">
          &larr; 返回首页
        </a>
      </div>
    </div>
  </article>
</Layout>

<style is:global>
  @reference "../styles/global.css";
  .markdown-content h2 {
    @apply text-2xl font-handwriting text-sakura-primary mt-10 mb-6 border-l-4 border-sakura-primary pl-3 bg-sakura-secondary/10 py-1;
  }
  .markdown-content p {
    @apply mb-4;
  }
  .markdown-content a {
    @apply text-blue-500 underline hover:text-sakura-primary transition-colors;
  }
  .markdown-content ol {
    @apply list-decimal pl-6 mb-6 space-y-2;
  }
  .markdown-content ul {
    @apply list-disc pl-6 mb-6 space-y-2;
  }
  .markdown-content strong {
    @apply text-sakura-primary font-bold;
  }
  .markdown-content .step-box {
    @apply bg-green-50 p-5 rounded-md border-l-4 border-green-400 mb-6 text-green-800 shadow-sm;
  }
</style>
